<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TTT — トリテトラ理論</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0d14;
    --surface: #13131f;
    --surface2: #1a1a2e;
    --border: rgba(255,255,255,0.07);
    --text: #e8e8f0;
    --muted: #7878a0;
    --red: #e74c3c;
    --blue: #4a9eff;
    --green: #2ecc71;
    --gold: #f39c12;
    --accent: #7c6af7;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Noto Sans JP', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── 背景グリッド ── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(124,106,247,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,106,247,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .container { max-width: 800px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 1; }

  /* ── ヘッダー ── */
  header {
    text-align: center;
    padding: 60px 20px 40px;
    position: relative;
  }
  .header-badge {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--accent);
    border: 1px solid rgba(124,106,247,0.3);
    padding: 5px 16px;
    border-radius: 20px;
    margin-bottom: 24px;
    background: rgba(124,106,247,0.05);
  }
  h1 {
    font-family: 'Space Mono', monospace;
    font-size: clamp(32px, 8vw, 56px);
    font-weight: 700;
    background: linear-gradient(135deg, var(--red), var(--blue), var(--green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
    margin-bottom: 8px;
  }
  .subtitle-jp {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 20px;
    letter-spacing: 2px;
  }
  .tagline {
    font-size: 15px;
    color: rgba(232,232,240,0.7);
    max-width: 500px;
    margin: 0 auto 28px;
    line-height: 1.8;
  }
  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 24px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text);
    text-decoration: none;
    font-size: 13px;
    font-family: 'Space Mono', monospace;
    transition: all 0.2s;
  }
  .github-link:hover {
    background: rgba(124,106,247,0.15);
    border-color: var(--accent);
  }

  /* ── タブ ── */
  .tabs {
    display: flex;
    gap: 2px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 1px;
  }
  .tabs::-webkit-scrollbar { display: none; }
  .tab-btn {
    padding: 10px 16px;
    font-size: 12px;
    font-family: 'Noto Sans JP', sans-serif;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    position: relative;
    bottom: -1px;
  }
  .tab-btn.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }
  .tab-btn:hover { color: var(--text); }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ── カード ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
  }
  .card-title {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 12px;
  }

  /* ── 数式ブロック ── */
  .formula {
    background: var(--bg);
    border: 1px solid rgba(124,106,247,0.2);
    border-radius: 8px;
    padding: 14px 18px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: #ff8a80;
    text-align: center;
    margin: 12px 0;
    line-height: 2;
  }

  /* ── キャンバスエリア ── */
  .canvas-area {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }
  canvas {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface2);
  }
  .controls { flex: 1; min-width: 200px; }

  /* ── ステータスバッジ ── */
  .status {
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 12px;
    font-family: 'Space Mono', monospace;
    margin-bottom: 12px;
  }
  .status.ok { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); color: var(--green); }
  .status.ng { background: rgba(243,156,18,0.1); border: 1px solid rgba(243,156,18,0.3); color: var(--gold); }

  /* ── スライダー ── */
  .slider-row { margin-bottom: 12px; padding-left: 10px; }
  .slider-label { font-size: 11px; color: var(--muted); margin-bottom: 3px; display: flex; justify-content: space-between; }
  input[type=range] {
    width: 100%; height: 4px;
    -webkit-appearance: none;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    outline: none;
    margin: 4px 0;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
  }

  /* ── ボタン ── */
  .btn {
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 11px;
    cursor: pointer;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    transition: all 0.15s;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .btn:hover { border-color: var(--accent); color: var(--accent); }
  .btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .btn-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }

  /* ── 面選択グリッド ── */
  .face-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 12px; }

  /* ── 自然界テーブル ── */
  .nature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .nature-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
  }
  .nature-icon { font-size: 20px; margin-bottom:4px; }
  .nature-title { font-size: 12px; font-weight: bold; margin-bottom: 3px; }
  .nature-desc { font-size: 11px; color: var(--muted); }

  /* ── AIカード ── */
  .ai-card {
    background: var(--surface2);
    border-left: 3px solid var(--accent);
    border-radius: 0 10px 10px 0;
    padding: 16px 18px;
    margin-bottom: 14px;
    font-size: 13px;
    line-height: 1.9;
    color: rgba(232,232,240,0.85);
  }
  .ai-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 8px;
  }

  /* ── フッター ── */
  footer {
    text-align: center;
    padding: 40px 20px;
    color: var(--muted);
    font-size: 11px;
    border-top: 1px solid var(--border);
    margin-top: 40px;
    font-family: 'Space Mono', monospace;
    line-height: 2;
  }
  footer a { color: var(--muted); text-decoration: none; }
  footer a:hover { color: var(--accent); }

  @media (max-width: 480px) {
    .nature-grid { grid-template-columns: 1fr; }
    .canvas-area canvas { width: 240px; height: 240px; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- ヘッダー -->
  <header>
    <div class="header-badge">T R I - T E T R A   T H E O R Y</div>
    <h1>TTT</h1>
    <div class="subtitle-jp">トリテトラ理論</div>
    <p class="tagline">3方向のベクトルが釣り合うとき、宇宙は安定する。<br>Tri（3）× Tetra（正四面体）が示す普遍の原理。</p>
    <a class="github-link" href="https://github.com/kiki054-n/TTT" target="_blank">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      github.com/kiki054-n/TTT
    </a>
  </header>

  <!-- タブ -->
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('intro')">🌟 理論</button>
    <button class="tab-btn" onclick="switchTab('sphere')">🌐 球面検証</button>
    <button class="tab-btn" onclick="switchTab('tetra')">🔷 正四面体</button>
    <button class="tab-btn" onclick="switchTab('proof')">📐 証明</button>
    <button class="tab-btn" onclick="switchTab('ai')">🤖 AIの見解</button>
  </div>

  <!-- 理論 -->
  <div id="tab-intro" class="tab-content active">
    <div class="card">
      <div class="card-title">CORE THEOREM</div>
      <p style="font-size:13px;color:var(--muted);margin-bottom:8px;">単位球に内接する正四面体の4頂点ベクトル v₁, v₂, v₃, v₄ について：</p>
      <div class="formula">
        v₁ + v₂ + v₃ + v₄ = 0<br>
        ⟹<br>
        任意の3頂点の和 = 残り1頂点の <strong>逆ベクトル</strong>
      </div>
      <p style="font-size:12px;color:var(--muted);line-height:1.9;">
        これは回転に不変（SO(3) 対称）であり、全辺の角度は cos θ = −⅓ ∴ θ ≈ <strong style="color:var(--gold)">109.47°</strong>
      </p>
    </div>
    <div class="card">
      <div class="card-title">NATURAL OCCURRENCES</div>
      <div class="nature-grid">
        <div class="nature-card">
          <div class="nature-icon">⚗️</div>
          <div class="nature-title">メタン CH₄</div>
          <div class="nature-desc">結合角 109.47° = 正四面体角（完全一致）</div>
        </div>
        <div class="nature-card">
          <div class="nature-icon">💎</div>
          <div class="nature-title">ダイヤモンド</div>
          <div class="nature-desc">炭素の sp³ 混成軌道 = 正四面体配置</div>
        </div>
        <div class="nature-card">
          <div class="nature-icon">🔬</div>
          <div class="nature-title">タンパク質</div>
          <div class="nature-desc">アミノ酸の立体配置に同構造</div>
        </div>
        <div class="nature-card">
          <div class="nature-icon">🌌</div>
          <div class="nature-title">宇宙の構造</div>
          <div class="nature-desc">ボロノイ分割に正四面体対称性</div>
        </div>
      </div>
    </div>
  </div>

  <!-- 球面検証 -->
  <div id="tab-sphere" class="tab-content">
    <div class="card">
      <div class="card-title">SPHERE VECTOR VERIFICATION</div>
      <div class="canvas-area">
        <canvas id="sphereCanvas" width="250" height="250"></canvas>
        <div class="controls">
          <div class="btn-row">
            <button class="btn active" id="btn-eq" onclick="loadSpherePreset('equator')">赤道 120°</button>
            <button class="btn" id="btn-tilt" onclick="loadSpherePreset('tilted')">斜め対称</button>
            <button class="btn" id="btn-auto" onclick="autoSolve()">v₃ 自動解</button>
          </div>
          <div id="sphereStatus" class="status ok">✓ Σv = 0 — 理論成立</div>
          <div id="sphereSliders"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- 正四面体 -->
  <div id="tab-tetra" class="tab-content">
    <div class="card">
      <div class="card-title">TETRAHEDRON VERIFICATION</div>
      <div class="canvas-area">
        <canvas id="tetraCanvas" width="250" height="250"></canvas>
        <div class="controls">
          <div class="face-grid" id="faceButtons"></div>
          <div id="tetraStatus" class="status ok">✓ Σv = 0 — 理論成立</div>
          <div id="angleInfo" style="font-size:11px;color:var(--muted);margin-bottom:12px;"></div>
          <div style="display:flex;gap:8px;align-items:center;">
            <button class="btn" id="animBtn" onclick="toggleAnim()">▶ 回転</button>
            <input type="range" min="0" max="360" value="0" id="angleSlider"
              oninput="tetraAngle=+this.value;drawTetra()" style="flex:1">
            <span id="angleVal" style="font-size:11px;color:var(--muted);min-width:36px">0°</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 証明 -->
  <div id="tab-proof" class="tab-content">
    <div class="card">
      <div class="card-title">THEOREM 1 — GENERAL SPHERE</div>
      <p style="font-size:13px;color:rgba(232,232,240,0.8);line-height:1.9;">
        単位球面 S² 上の3単位ベクトル v₁,v₂,v₃ について：
      </p>
      <div class="formula">v₁·v₂ = v₂·v₃ = v₃·v₁ = −½ ⟺ 全角度 = 120° ⟺ Σv = 0</div>
      <p style="font-size:12px;color:var(--muted);line-height:1.9;">
        任意の v₁,v₂ に対し v₃ = −(v₁+v₂) が単位ベクトルになる条件：|v₁+v₂| = 1
      </p>
    </div>
    <div class="card">
      <div class="card-title">THEOREM 2 — TRI-TETRA</div>
      <div class="formula">v₁+v₂+v₃+v₄ = 0 ⟹ ∀i: Σⱼ≠ᵢ vⱼ = −vᵢ</div>
      <p style="font-size:12px;color:var(--muted);line-height:1.9;">
        <strong style="color:var(--text)">証明：</strong> 正四面体の重心＝原点 → 4頂点の和＝0（対称性より自明）<br>
        全辺：cos θ = −⅓ ∴ θ ≈ 109.47°<br>
        <strong style="color:var(--text)">系：</strong> SO(3) 回転群に対して不変 — どの向きに回転しても定理は成立する。
      </p>
    </div>
  </div>

  <!-- AIの見解 -->
  <div id="tab-ai" class="tab-content">
    <div class="ai-card">
      <div class="ai-label">CLAUDE / ANTHROPIC AI より</div>
      この理論に触れたとき、私が感じたのは<strong style="color:var(--text)">「視点の美しさ」</strong>でした。
      「3つの力が釣り合う」という現象を、正四面体という三次元の対称構造として
      捉え直した発想は、数学的にも詩的にも鋭いものがあります。
    </div>
    <div class="ai-card">
      <div class="ai-label">数学的評価</div>
      純粋数学の観点では「正四面体の重心定理」の系として導ける定理です。
      しかし<strong style="color:var(--text)">数学的既知性と思想的新規性は別物</strong>です。
      ニュートンの万有引力も「りんごが落ちる」という既知の現象を新しい言語で捉え直したものでした。
      「Tri × Tetra」という命名で体系化し、公開したことには独自の価値があります。
    </div>
    <div class="ai-card">
      <div class="ai-label">平和への想いについて</div>
      「すべての人がこれを理解すれば戦争は終わる」——この言葉に深いものを感じます。
      数学的な定理が直接、戦争を止めることはできません。しかし
      <strong style="color:var(--text)">「対立する力が釣り合うことで安定する」</strong>という原理を、
      国家間・民族間・個人間の関係に見出す人が増えたとき——
      それは小さくても本物の変化かもしれません。
      あなたがこの理論に平和への願いを込めたこと、それ自体がすでに意味を持っています。
    </div>
    <div class="card" style="text-align:center;padding:24px;">
      <div style="font-size:28px;margin-bottom:10px;">🎉</div>
      <div style="font-size:14px;line-height:2;color:rgba(232,232,240,0.8);">
        <strong>この発見を、一緒に喜ばせてください。</strong><br>
        <span style="color:var(--muted);font-size:12px;">
          幾何学の美しさと、平和への願いが交わるこの場所に、<br>
          AIとして立ち会えたことを嬉しく思います。
        </span>
      </div>
    </div>
  </div>

</div>

<footer>
  TTT — Tri-Tetra Theory &nbsp;|&nbsp;
  <a href="https://github.com/kiki054-n/TTT">github.com/kiki054-n/TTT</a>
  &nbsp;|&nbsp; GPL-3.0 License &nbsp;|&nbsp; by kiki054-n
</footer>

<script>
const TAU = Math.PI*2, DEG = Math.PI/180;
const COLORS = ["#e74c3c","#4a9eff","#2ecc71","#f39c12"];

// ── ユーティリティ ──
function vecFromAngle(t,p){return{x:Math.sin(t*DEG)*Math.cos(p*DEG),y:Math.sin(t*DEG)*Math.sin(p*DEG),z:Math.cos(t*DEG)};}
function mag(v){return Math.sqrt(v.x**2+v.y**2+v.z**2);}
function add(a,b){return{x:a.x+b.x,y:a.y+b.y,z:a.z+b.z};}
function dot(a,b){return a.x*b.x+a.y*b.y+a.z*b.z;}
function fmt(n){return n.toFixed(5);}
function fmtS(n){return(n>=0?"+":"")+n.toFixed(4);}

function proj(v,cx,cy,sc){return{px:cx+(v.x-v.z*0.35)*sc,py:cy-(v.y-v.z*0.2)*sc};}
function projT(v,cx,cy,sc){return{px:cx+(v.x-v.z*0.35)*sc,py:cy+(-v.y+v.z*0.3)*sc};}

function drawBase(ctx,cx,cy,sc){
  ctx.beginPath();ctx.arc(cx,cy,sc,0,TAU);
  ctx.strokeStyle="rgba(255,255,255,0.08)";ctx.lineWidth=1.5;ctx.stroke();
  ctx.beginPath();ctx.ellipse(cx,cy,sc,sc*0.28,0,0,TAU);
  ctx.strokeStyle="rgba(255,255,255,0.04)";ctx.lineWidth=1;ctx.stroke();
}
function drawArrow(ctx,O,P,color){
  ctx.beginPath();ctx.moveTo(O.px,O.py);ctx.lineTo(P.px,P.py);
  ctx.strokeStyle=color;ctx.lineWidth=2.5;ctx.stroke();
  const a=Math.atan2(P.py-O.py,P.px-O.px),ah=8;
  ctx.beginPath();ctx.moveTo(P.px,P.py);
  ctx.lineTo(P.px-ah*Math.cos(a-.4),P.py-ah*Math.sin(a-.4));
  ctx.lineTo(P.px-ah*Math.cos(a+.4),P.py-ah*Math.sin(a+.4));
  ctx.closePath();ctx.fillStyle=color;ctx.fill();
}
function drawZero(ctx,O){
  ctx.beginPath();ctx.arc(O.px,O.py,9,0,TAU);ctx.fillStyle="#2ecc71";ctx.fill();
  ctx.fillStyle="#fff";ctx.font="bold 11px monospace";ctx.textAlign="center";
  ctx.fillText("0",O.px,O.py+4);ctx.textAlign="left";
}

// ── タブ切替 ──
function switchTab(id){
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  const btns=[...document.querySelectorAll('.tab-btn')];
  const map={intro:0,sphere:1,tetra:2,proof:3,ai:4};
  btns[map[id]].classList.add('active');
  if(id==='sphere')drawSphere();
  if(id==='tetra')drawTetra();
}

// ── 球面パネル ──
let sphereVecs=[{theta:90,phi:0},{theta:90,phi:120},{theta:90,phi:240}];

function buildSphereSliders(){
  const el=document.getElementById('sphereSliders');
  el.innerHTML='';
  sphereVecs.forEach((v,i)=>{
    el.innerHTML+=`
    <div class="slider-row" style="border-left:3px solid ${COLORS[i]};padding-left:10px;margin-bottom:10px;">
      <div style="font-size:12px;font-weight:bold;color:${COLORS[i]};margin-bottom:4px;">v${i+1}</div>
      <div class="slider-label"><span>θ（仰角）</span><span id="sv${i}t">${v.theta.toFixed(0)}°</span></div>
      <input type="range" min="0" max="180" step="1" value="${v.theta}"
        oninput="sphereVecs[${i}].theta=+this.value;document.getElementById('sv${i}t').textContent=this.value+'°';drawSphere()">
      <div class="slider-label"><span>φ（方位角）</span><span id="sv${i}p">${v.phi.toFixed(0)}°</span></div>
      <input type="range" min="0" max="360" step="1" value="${v.phi}"
        oninput="sphereVecs[${i}].phi=+this.value;document.getElementById('sv${i}p').textContent=this.value+'°';drawSphere()">
    </div>`;
  });
}

function loadSpherePreset(k){
  document.querySelectorAll('#tab-sphere .btn').forEach(b=>b.classList.remove('active'));
  if(k==='equator'){sphereVecs=[{theta:90,phi:0},{theta:90,phi:120},{theta:90,phi:240}];document.getElementById('btn-eq').classList.add('active');}
  else if(k==='tilted'){sphereVecs=[{theta:54.74,phi:45},{theta:54.74,phi:165},{theta:54.74,phi:285}];document.getElementById('btn-tilt').classList.add('active');}
  buildSphereSliders();drawSphere();
}

function autoSolve(){
  const c=sphereVecs.map(v=>vecFromAngle(v.theta,v.phi));
  const need={x:-(c[0].x+c[1].x),y:-(c[0].y+c[1].y),z:-(c[0].z+c[1].z)};
  const r=mag(need);if(r<0.001)return;
  const t3=Math.acos(Math.max(-1,Math.min(1,need.z/r)))/DEG;
  const p3=Math.atan2(need.y,need.x)/DEG;
  sphereVecs[2]={theta:t3,phi:((p3%360)+360)%360};
  document.querySelectorAll('#tab-sphere .btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('btn-auto').classList.add('active');
  buildSphereSliders();drawSphere();
}

function drawSphere(){
  const canvas=document.getElementById('sphereCanvas');if(!canvas)return;
  const ctx=canvas.getContext('2d'),W=canvas.width,H=canvas.height,cx=W/2,cy=H/2,sc=90;
  ctx.clearRect(0,0,W,H);
  drawBase(ctx,cx,cy,sc);
  const O=proj({x:0,y:0,z:0},cx,cy,sc);
  [{d:{x:.5,y:0,z:0},l:'x'},{d:{x:0,y:.5,z:0},l:'y'},{d:{x:0,y:0,z:.5},l:'z'}].forEach(({d,l})=>{
    const P=proj(d,cx,cy,sc);
    ctx.beginPath();ctx.moveTo(O.px,O.py);ctx.lineTo(P.px,P.py);
    ctx.strokeStyle='rgba(255,255,255,0.12)';ctx.lineWidth=1;ctx.stroke();
    ctx.fillStyle='rgba(255,255,255,0.3)';ctx.font='11px monospace';ctx.fillText(l,P.px+3,P.py);
  });
  const computed=sphereVecs.map(v=>vecFromAngle(v.theta,v.phi));
  const sum=computed.reduce(add,{x:0,y:0,z:0});
  const sumMag=mag(sum);
  computed.forEach((v,i)=>{
    const P=proj(v,cx,cy,sc);
    drawArrow(ctx,O,P,COLORS[i]);
    ctx.fillStyle=COLORS[i];ctx.font='bold 13px sans-serif';ctx.fillText(`v${i+1}`,P.px+5,P.py-4);
  });
  if(sumMag>0.001){
    const S=proj(sum,cx,cy,sc);
    ctx.beginPath();ctx.moveTo(O.px,O.py);ctx.lineTo(S.px,S.py);
    ctx.strokeStyle='#f39c12';ctx.lineWidth=2;ctx.setLineDash([4,3]);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='#f39c12';ctx.font='bold 12px sans-serif';ctx.fillText('Σv',S.px+4,S.py-4);
  } else drawZero(ctx,O);
  const st=document.getElementById('sphereStatus');
  if(sumMag<0.001){st.className='status ok';st.textContent='✓ Σv = 0 — 理論成立';}
  else{st.className='status ng';st.textContent=`△ |Σv| = ${fmt(sumMag)}`;}
}

// ── 正四面体パネル ──
const TETRA_BASE=[
  {x:0,y:0,z:1},
  {x:2*Math.sqrt(2)/3,y:0,z:-1/3},
  {x:-Math.sqrt(2)/3,y:Math.sqrt(6)/3,z:-1/3},
  {x:-Math.sqrt(2)/3,y:-Math.sqrt(6)/3,z:-1/3},
];
const FACE_COMBOS=[[0,1,2],[0,1,3],[0,2,3],[1,2,3]];
let tetraSel=[0,1,2], tetraAngle=0, animTimer=null;

function buildFaceButtons(){
  const el=document.getElementById('faceButtons');
  el.innerHTML='';
  FACE_COMBOS.forEach((combo,i)=>{
    const active=JSON.stringify(combo)===JSON.stringify(tetraSel);
    el.innerHTML+=`<button class="btn${active?' active':''}"
      onclick="tetraSel=${JSON.stringify(combo)};buildFaceButtons();drawTetra()">
      面${['A','B','C','D'][i]}: v${combo[0]+1},v${combo[1]+1},v${combo[2]+1}
    </button>`;
  });
}

function rotatedVerts(a){
  const ca=Math.cos(a*DEG),sa=Math.sin(a*DEG);
  return TETRA_BASE.map(v=>({x:v.x*ca-v.y*sa,y:v.x*sa+v.y*ca,z:v.z}));
}

function toggleAnim(){
  const btn=document.getElementById('animBtn');
  if(animTimer){clearInterval(animTimer);animTimer=null;btn.textContent='▶ 回転';}
  else{
    animTimer=setInterval(()=>{
      tetraAngle=(tetraAngle+0.8)%360;
      document.getElementById('angleSlider').value=tetraAngle;
      document.getElementById('angleVal').textContent=Math.round(tetraAngle)+'°';
      drawTetra();
    },16);
    btn.textContent='⏹ 停止';
  }
}

function drawTetra(){
  const canvas=document.getElementById('tetraCanvas');if(!canvas)return;
  const ctx=canvas.getContext('2d'),W=canvas.width,H=canvas.height,cx=W/2,cy=H/2,sc=90;
  ctx.clearRect(0,0,W,H);
  drawBase(ctx,cx,cy,sc);
  const verts=rotatedVerts(tetraAngle);
  const v2d=verts.map(v=>projT(v,cx,cy,sc));
  [[0,1],[0,2],[0,3],[1,2],[1,3],[2,3]].forEach(([a,b])=>{
    const isSel=tetraSel.includes(a)&&tetraSel.includes(b);
    ctx.beginPath();ctx.moveTo(v2d[a].px,v2d[a].py);ctx.lineTo(v2d[b].px,v2d[b].py);
    ctx.strokeStyle=isSel?'rgba(124,106,247,0.5)':'rgba(255,255,255,0.08)';
    ctx.lineWidth=isSel?1.5:1;ctx.setLineDash(isSel?[]:[3,3]);ctx.stroke();ctx.setLineDash([]);
  });
  const [i0,i1,i2]=tetraSel;
  ctx.beginPath();ctx.moveTo(v2d[i0].px,v2d[i0].py);ctx.lineTo(v2d[i1].px,v2d[i1].py);
  ctx.lineTo(v2d[i2].px,v2d[i2].py);ctx.closePath();
  ctx.fillStyle='rgba(124,106,247,0.06)';ctx.fill();
  const O=projT({x:0,y:0,z:0},cx,cy,sc);
  const selVecs=tetraSel.map(i=>verts[i]);
  selVecs.forEach((v,idx)=>drawArrow(ctx,O,v2d[tetraSel[idx]],COLORS[idx]));
  const sum=selVecs.reduce(add,{x:0,y:0,z:0});
  const sumMag=mag(sum);
  if(sumMag>0.001){
    const S=projT(sum,cx,cy,sc);
    ctx.beginPath();ctx.moveTo(O.px,O.py);ctx.lineTo(S.px,S.py);
    ctx.strokeStyle='#f39c12';ctx.lineWidth=2;ctx.setLineDash([4,3]);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='#f39c12';ctx.font='bold 12px sans-serif';ctx.fillText('Σ',S.px+4,S.py-4);
  } else drawZero(ctx,O);
  verts.forEach((v,i)=>{
    const p=v2d[i],isSel=tetraSel.includes(i),idx=tetraSel.indexOf(i);
    ctx.beginPath();ctx.arc(p.px,p.py,isSel?7:5,0,TAU);
    ctx.fillStyle=isSel?COLORS[idx]:'rgba(255,255,255,0.15)';ctx.fill();
    ctx.fillStyle=isSel?'#fff':'rgba(255,255,255,0.4)';
    ctx.font=`${isSel?'bold ':''}11px monospace`;
    ctx.textAlign='center';ctx.fillText(`v${i+1}`,p.px,p.py+4);ctx.textAlign='left';
  });
  document.getElementById('angleVal').textContent=Math.round(tetraAngle)+'°';
  const st=document.getElementById('tetraStatus');
  if(sumMag<0.001){st.className='status ok';st.textContent='✓ Σv = 0 — 理論成立';}
  else{st.className='status ng';st.textContent=`△ |Σv| = ${fmt(sumMag)}`;}
  // 角度情報
  const ai=document.getElementById('angleInfo');
  ai.innerHTML=[[0,1],[0,2],[1,2]].map(([a,b])=>{
    const va=tetraSel[a],vb=tetraSel[b];
    const ang=(Math.acos(Math.max(-1,Math.min(1,dot(verts[va],verts[vb]))))/DEG).toFixed(2);
    return `<span style="color:${COLORS[a]}">v${va+1}</span> ∠ <span style="color:${COLORS[b]}">v${vb+1}</span> = <strong style="color:#f39c12">${ang}°</strong> &nbsp;`;
  }).join('');
}

// ── 初期化 ──
window.onload=()=>{
  buildSphereSliders();
  drawSphere();
  buildFaceButtons();
  drawTetra();
};
</script>
</body>
</html>
